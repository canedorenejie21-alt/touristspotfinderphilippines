# Local fallback:
# DATABASE_URL=sqlite:///./tourist_spot_finder.db

# Neon PostgreSQL example:
# DATABASE_URL=postgresql+psycopg://USER:PASSWORD@HOST.neon.tech/DBNAME?sslmode=require

DATABASE_URL=sqlite:///./tourist_spot_finder.db
APP_SECRET_KEY=change-this-secret-before-deploy
FRONTEND_ORIGINS=http://localhost:8080,http://127.0.0.1:8080

# Email OTP verification. Gmail needs 2-Step Verification + App Password.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=yourgmail@gmail.com
SMTP_PASSWORD=your_16_character_app_password
SMTP_FROM_EMAIL=yourgmail@gmail.com
OTP_EXPIRY_MINUTES=10
ADMIN_KEY=tourist-admin-123
ADMIN_EMAILS=admin@example.com
